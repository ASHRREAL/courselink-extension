{
  "manifest_version": 3,
  "name": "CourseLink+",
  "version": "1.0.0",
  "description": "Better CourseLink.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CourseLink+ Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "*://courselink.uoguelph.ca/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://courselink.uoguelph.ca/*"
  ]
}
